<style>
*{
    margin:0;padding:0;box-sizing:border-box;
    -webkit-user-select:none !important;
    -khtml-user-select:none !important;
    -moz-user-select:none !important;
    -ms-user-select:none !important;
    user-select:none !important;
    -webkit-touch-callout:none !important;
    touch-callout:none !important;
}
#pwd, #pwd *{
    -webkit-user-select:text !important;
    user-select:text !important;
}
body{
    min-height:100vh;
    background:#0a0a12;
    background-size:cover;
    background-position:center;
    background-attachment:fixed;
    font-family:Consolas,Courier New,monospace;
    display:flex;
    align-items:center;
    justify-content:center;
    color:#e0e0ff;
    opacity:0;
    visibility:hidden;
    transition:all 1s ease
}
body.ready{opacity:1;visibility:visible}
.free-tip{
    position:fixed;
    top:20px;
    left:50%;
    transform:translateX(-50%);
    font-size:16px;
    color:#ffd000;
    text-shadow:0 0 8px rgba(25,30,60,.5);
    font-weight:bold;
    z-index:998;
    pointer-events:none;
    transition:opacity .6s ease
}
.free-tip.hide{opacity:0}
.lock-wrapper{
    position:fixed;
    top:50%;
    left:50%;
    transform:translate(-50%,-50%) scale(0.8);
    z-index:999;
    opacity:0;
    transition:all .8s cubic-bezier(.25,.46,.45,.94)
}
.lock-wrapper.show{
    opacity:1;
    transform:translate(-50%,-50%) scale(1)
}
.lock-wrapper.hide{
    opacity:0;
    transform:translate(-50%,-50%) translateY(-50px) scale(.9);
    pointer-events:none
}
.border-wrapper{
    padding:2px;
    border-radius:24px;
    background:linear-gradient(90deg,#00f5ff,#ff00d4,#ffd000,#00f5ff);
    background-size:300% 100%;
    animation:borderGlow 4s infinite
}
@keyframes borderGlow{
    0%{background-position:0%}
    100%{background-position:300%}
}
.lock-container{
    width:300px;
    padding:3rem 2rem;
    border-radius:22px;
    background:rgba(15,15,30,.95);
    text-align:center
}
.logo{
    width:80px;
    height:80px;
    margin:0 auto 1.5rem;
    border-radius:50%;
    background:linear-gradient(135deg,#00f5ff,#ff00d4);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:2.5em;
    font-weight:bold;
    color:#0a0a12
}
.lock-container h2{
    font-size:1.8em;
    letter-spacing:2px;
    margin-bottom:2.5rem;
    color:#fff
}
#pwd{
    width:100%;
    padding:1.2rem 1rem;
    margin-bottom:1.5rem;
    border:1px solid #00f5ff;
    border-radius:12px;
    background:rgba(5,5,20,.6);
    color:#fff;
    font-family:inherit;
    outline:none;
    pointer-events:auto;
    touch-action:manipulation
}
#btn{
    width:100%;
    padding:1.2rem;
    border:none;
    border-radius:12px;
    background:linear-gradient(90deg,#00f5ff,#ff00d4);
    color:#0a0a12;
    font-weight:bold;
    cursor:pointer;
    position:relative;
    z-index:10;
    touch-action:manipulation;
    transition: transform 0.2s ease;
}
#btn:active{
    transform: scale(0.96);
}
#err{
    margin-top:1rem;
    color:#ff4466;
    font-size:.9em;
    display:none
}
#tools{
    width:300px;
    padding:2px;
    border-radius:24px;
    background:linear-gradient(90deg,#00f5ff,#ff00d4,#ffd000,#00f5ff);
    background-size:300% 100%;
    animation:borderGlow 4s infinite;
    opacity:0;
    pointer-events:none;
    transition:all .8s .3s;
    position:relative;
    z-index:9
}
#tools.show{opacity:1;pointer-events:all}
.tool-inner{
    padding:20px 1.5rem 1.5rem;
    border-radius:22px;
    background:rgba(15,15,30,.95);
    position:relative
}
#clock{
    position:absolute;
    top:5px;
    left:10px;
    color:#00f5ff;
    font-size:.8em
}
.preset-buttons{display:grid;gap:10px}
.preset-btn{
    padding:1.2rem 0;
    border:1px solid #ffb703;
    border-radius:8px;
    background:rgba(30,25,18,.8);
    color:#ffd666;
    cursor:pointer;
    font-size:.9em;
    position:relative;
    z-index:10;
    touch-action:manipulation;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.2s ease;
}
.preset-btn:active:not(.disabled){
    transform: scale(0.96);
}
.preset-btn.disabled{
    opacity:.5;
    border-color:#666;
    color:#999;
    pointer-events:none
}
.qr-modal{
    display:none;
    position:fixed;
    inset:0;
    background:#000c;
    z-index:99999;
    justify-content:center;
    align-items:center
}
.qr-modal.show{display:flex}
.qr-box{
    background:#fff;
    padding:16px;
    border-radius:14px;
    text-align:center
}
.qr-close{
    font-size:22px;
    cursor:pointer;
    margin-bottom:8px
}
.update-modal{
  display:none;
  position:fixed;
  inset:0;
  background:rgba(0,0,0,0.85);
  z-index:999999;
  align-items:center;
  justify-content:center;
}
.update-box{
  background:#111;
  width:280px;
  padding:24px;
  border-radius:16px;
  border:1px solid #00f5ff;
  text-align:center;
  color:#fff;
}
.update-box h3{
  margin-bottom:12px;
  color:#ffd000;
}
.update-box p{
  margin-bottom:20px;
  font-size:14px;
  line-height:1.4;
}
.update-btn{
  padding:10px 20px;
  background:linear-gradient(90deg,#00f5ff,#ff00d4);
  border:none;
  border-radius:8px;
  color:#000;
  font-weight:bold;
  cursor:pointer;
  width:100%;
  outline: none;
  -webkit-tap-highlight-color: transparent;
  transition: transform 0.2s ease;
}
.update-btn:active{
    transform: scale(0.96);
}
.later-btn{
  margin-top:10px;
  padding:8px 20px;
  background:#333;
  border:1px solid #666;
  border-radius:8px;
  color:#fff;
  cursor:pointer;
  width:100%;
  font-size:12px;
  outline: none;
  -webkit-tap-highlight-color: transparent;
  transition: transform 0.2s ease;
}
.later-btn:active{
    transform: scale(0.96);
}
</style>
</head>
<body>

<div class="free-tip" id="freeTip">7️⃣8️⃣9️⃣1️⃣</div>

